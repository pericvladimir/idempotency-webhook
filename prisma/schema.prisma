// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model IdempotencyKey {
  id              Int           @id @default(autoincrement())
  key             String        @unique
  requestBodyHash String
  recoveryPoint   String        @default("started")
  responseCode    Int?
  responseBody    Json?
  lockedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  webhookEvent    WebhookEvent?

  @@index([createdAt])
  @@map("idempotency_keys")
}

model WebhookEvent {
  id               Int              @id @default(autoincrement())
  source           String
  sourceEvent      String
  processingStatus ProcessingStatus @default(RECEIVED)
  payload          Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lastAttemptedAt  DateTime?
  errorMessage     String?
  idempotencyKey   IdempotencyKey?  @relation(fields: [idempotencyKeyId], references: [id])
  idempotencyKeyId Int?             @unique
  retryCount       Int              @default(0)

  @@index([source, processingStatus])
  @@map("webhook_events")
}

enum ProcessingStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED
}
